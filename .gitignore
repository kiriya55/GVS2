# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
output/
*.egg-info
*.spec

# Executables and artifacts
*.bat
*.exe
*.bak

# Logs
logs/
*.log

# Tests (user-local)
test*.py

# Virtual environments
.venv

# Personal config (use config.example.json as template)
config.json

# Workspace files
.workbuddy/
.codebuddy/
.claude/

# Package locks (regenerated by users)
uv.lock

# Release build output
release/

# Style samples (local backup, not part of LLM workflow)
style_samples/*.json
style_samples/*.webp
style_samples/*.jpg

# OS files
.DS_Store
Thumbs.db
